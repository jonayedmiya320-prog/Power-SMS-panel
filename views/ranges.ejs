<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Power SMS | SMS Ranges</title>
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
  <div class="layout">
    <%- include('partials/sidebar', { active: active, user: user }) %>
    <div class="main">
      <%- include('partials/topbar', { pageTitle: pageTitle, user: user }) %>
      <div class="content">

        <% if (user.role === 'superadmin') { %>
        <div class="page-card">
          <h3>Add New Range</h3>
          <form method="POST" action="/ranges/create">
            <div class="form-row">
              <label>Country / Operator</label>
              <input type="text" name="country" required>
            </div>
            <div class="form-row">
              <label>Prefix</label>
              <input type="text" name="prefix" required>
            </div>
            <div class="form-row">
              <label>Test Number</label>
              <input type="text" name="testNumber">
            </div>
            <div class="form-row">
              <label>Currency</label>
              <input type="text" name="currency" placeholder="USD">
            </div>
            <div class="form-row">
              <label>Payout</label>
              <input type="text" name="payout" placeholder="0.00">
            </div>
            <button type="submit" class="btn-primary">Add Range</button>
          </form>
        </div>
        <% } %>

        <div class="page-card">
          <h3>All SMS Ranges</h3>
          <table class="data-table">
            <thead>
              <tr>
                <th>Country</th>
                <th>Prefix</th>
                <th>Test Number</th>
                <th>Currency</th>
                <th>Payout</th>
                <% if (user.role === 'superadmin') { %><th>Action</th><% } %>
              </tr>
            </thead>
            <tbody>
              <% if (ranges.length === 0) { %>
                <tr><td colspan="6">No ranges added yet.</td></tr>
              <% } %>
              <% ranges.forEach(function(r) { %>
                <tr>
                  <td><%= r.country %></td>
                  <td><%= r.prefix %></td>
                  <td><%= r.testNumber %></td>
                  <td><%= r.currency %></td>
                  <td><%= r.payout %></td>
                  <% if (user.role === 'superadmin') { %>
                  <td>
                    <form method="POST" action="/ranges/delete/<%= r.id %>" style="display:inline">
                      <button type="submit" class="btn-primary" style="padding:5px 10px;font-size:12px;background:#dc2626;">Delete</button>
                    </form>
                  </td>
                  <% } %>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

      </div>
    </div>
  </div>
</body>
</html>