<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Power SMS | My Clients</title>
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
  <div class="layout">
    <%- include('partials/sidebar', { active: active, user: user }) %>
    <div class="main">
      <%- include('partials/topbar', { pageTitle: pageTitle, user: user }) %>
      <div class="content">

        <div class="page-card">
          <h3>Add New Client</h3>
          <form method="POST" action="/agent-clients/create">
            <div class="form-row">
              <label>Full Name</label>
              <input type="text" name="name" required>
            </div>
            <div class="form-row">
              <label>Username</label>
              <input type="text" name="username" required>
            </div>
            <div class="form-row">
              <label>Password</label>
              <input type="password" name="password" required minlength="6">
            </div>
            <button type="submit" class="btn-primary">Add Client</button>
          </form>
        </div>

        <div class="page-card">
          <h3>My Numbers (Give to Client)</h3>
          <table class="data-table">
            <thead>
              <tr>
                <th>Range</th>
                <th>Number</th>
                <th>Given To</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (myNumbers.length === 0) { %>
                <tr><td colspan="4">No numbers assigned to you yet.</td></tr>
              <% } %>
              <% myNumbers.forEach(function(n) { %>
                <tr>
                  <td><%= n.range %></td>
                  <td><%= n.number %></td>
                  <td><%= n.givenTo || '-' %></td>
                  <td>
                    <form method="POST" action="/agent-clients/give-number/<%= n.id %>" style="display:inline">
                      <select name="givenTo" style="padding:4px;font-size:12px;">
                        <option value="">-- Take Back --</option>
                        <% myClients.forEach(function(c) { %>
                          <option value="<%= c.username %>" <%= n.givenTo === c.username ? 'selected' : '' %>><%= c.username %></option>
                        <% }); %>
                      </select>
                      <button type="submit" class="btn-primary" style="padding:5px 10px;font-size:12px;">Set</button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <div class="page-card">
          <h3>My Client List</h3>
          <table class="data-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Username</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% if (myClients.length === 0) { %>
                <tr><td colspan="3">No clients added yet.</td></tr>
              <% } %>
              <% myClients.forEach(function(c) { %>
                <tr>
                  <td><%= c.name %></td>
                  <td><%= c.username %></td>
                  <td><span class="badge <%= c.status === 'active' ? 'badge-active' : 'badge-inactive' %>"><%= c.status %></span></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

      </div>
    </div>
  </div>
</body>
</html>