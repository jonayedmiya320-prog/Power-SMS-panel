<!DOCTYPE html>
<html lang="bn">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Power SMS | প্রথম সেটআপ</title>
  <link rel="stylesheet" href="/css/login.css">
</head>
<body>
  <div class="login-wrap">
    <div class="login-card">
      <div class="login-brand">
        <span class="brand-mark">P</span>
        <h1>Power SMS</h1>
        <p>প্রথম Super Admin অ্যাকাউন্ট তৈরি করুন</p>
      </div>

      <% if (error) { %>
        <div class="login-error"><%= error %></div>
      <% } %>

      <form method="POST" action="/setup" class="login-form">
        <label for="name">আপনার নাম</label>
        <input type="text" id="name" name="name" placeholder="যেমন: Sadhin">

        <label for="username">ইউজারনেম</label>
        <input type="text" id="username" name="username" required autofocus>

        <label for="password">পাসওয়ার্ড</label>
        <input type="password" id="password" name="password" required minlength="6">

        <button type="submit">Super Admin তৈরি করুন</button>
      </form>
    </div>
  </div>
</body>
</html>