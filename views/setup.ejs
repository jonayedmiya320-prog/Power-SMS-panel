<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Power SMS | Initial Setup</title>
  <link rel="stylesheet" href="/css/login.css">
</head>
<body>
  <div class="login-wrap">
    <div class="login-card">
      <div class="login-brand">
        <span class="brand-mark">P</span>
        <h1>Power SMS</h1>
        <p>Create the first Super Admin account</p>
      </div>

      <% if (error) { %>
        <div class="login-error"><%= error %></div>
      <% } %>

      <form method="POST" action="/setup" class="login-form">
        <label for="name">Full Name</label>
        <input type="text" id="name" name="name" placeholder="e.g. Sadhin">

        <label for="username">Username</label>
        <input type="text" id="username" name="username" required autofocus>

        <label for="password">Password</label>
        <input type="password" id="password" name="password" required minlength="6">

        <button type="submit">Create Super Admin</button>
      </form>
    </div>
  </div>
</body>
</html>