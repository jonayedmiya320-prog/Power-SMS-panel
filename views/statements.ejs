<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Power SMS | Statements</title>
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
  <div class="layout">
    <%- include('partials/sidebar', { active: active, user: user }) %>
    <div class="main">
      <%- include('partials/topbar', { pageTitle: pageTitle, user: user }) %>
      <div class="content">

        <div class="page-card">
          <h3>Account Statements</h3>
          <table class="data-table">
            <thead>
              <tr>
                <th>Date</th>
                <th>Description</th>
                <th>Debit</th>
                <th>Credit</th>
                <th>Balance</th>
                <th>Currency</th>
              </tr>
            </thead>
            <tbody>
              <% if (entries.length === 0) { %>
                <tr><td colspan="6">No statement entries yet.</td></tr>
              <% } %>
              <% entries.forEach(function(e) { %>
                <tr>
                  <td><%= new Date(e.date).toLocaleDateString() %></td>
                  <td><%= e.description %></td>
                  <td><%= e.debit.toFixed(2) %></td>
                  <td><%= e.credit.toFixed(2) %></td>
                  <td><%= e.balance.toFixed(2) %></td>
                  <td><%= e.currency %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

      </div>
    </div>
  </div>
</body>
</html>