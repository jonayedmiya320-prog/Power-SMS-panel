<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Power SMS | Dashboard</title>
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
  <div class="layout">
    <%- include('partials/sidebar', { active: active, user: user }) %>

    <div class="main">
      <%- include('partials/topbar', { pageTitle: pageTitle, user: user }) %>

      <div class="content">

        <div class="icon-grid">
          <a href="/dashboard" class="icon-card">
            <span class="icon-emoji">🖥️</span>
            <span class="icon-label">Dashboard</span>
          </a>
          <a href="/clients" class="icon-card">
            <span class="icon-emoji">👤</span>
            <span class="icon-label">Clients</span>
          </a>
          <a href="/sms-test" class="icon-card">
            <span class="icon-emoji">📡</span>
            <span class="icon-label">SMS Test</span>
          </a>
          <a href="/reports" class="icon-card">
            <span class="icon-emoji">📊</span>
            <span class="icon-label">Statistics</span>
          </a>
          <a href="/credit-notes" class="icon-card">
            <span class="icon-emoji">💼</span>
            <span class="icon-label">Credit Notes</span>
          </a>
        </div>

        <div class="stat-grid">
          <div class="stat-card">
            <div class="stat-label">Today's SMS</div>
            <div class="stat-value"><%= stats.smsToday %></div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Last 7 Days SMS</div>
            <div class="stat-value"><%= stats.sms7Day %></div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Last 30 Days SMS</div>
            <div class="stat-value"><%= stats.sms30Day %></div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Total Clients</div>
            <div class="stat-value"><%= stats.totalClients %></div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Total Admins</div>
            <div class="stat-value"><%= stats.totalAdmins %></div>
          </div>
        </div>

        <div class="welcome-box">
          <h2>Welcome, <%= user.name %></h2>
          <p>You are logged in as <strong><%= user.role %></strong>. SMS data will appear here once a provider is connected.</p>
        </div>
      </div>
    </div>
  </div>
</body>
</html>