<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Power SMS | Payment Requests</title>
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
  <div class="layout">
    <%- include('partials/sidebar', { active: active, user: user }) %>
    <div class="main">
      <%- include('partials/topbar', { pageTitle: pageTitle, user: user }) %>
      <div class="content">

        <div class="page-card">
          <h3>New Payment Request</h3>
          <form method="POST" action="/payment-requests/create">
            <div class="form-row">
              <label>Amount</label>
              <input type="text" name="amount" placeholder="e.g. 100.00" required>
            </div>
            <div class="form-row">
              <label>Payment Method</label>
              <input type="text" name="method" placeholder="e.g. Bank Transfer" required>
            </div>
            <button type="submit" class="btn-primary">Submit Request</button>
          </form>
        </div>

        <div class="page-card">
          <h3>Payment Request History</h3>
          <table class="data-table">
            <thead>
              <tr>
                <th>Amount</th>
                <th>Method</th>
                <th>Status</th>
                <th>Requested By</th>
                <th>Date</th>
                <% if (user.role === 'superadmin' || user.role === 'subadmin') { %><th>Action</th><% } %>
              </tr>
            </thead>
            <tbody>
              <% if (requests.length === 0) { %>
                <tr><td colspan="6">No payment requests yet.</td></tr>
              <% } %>
              <% requests.forEach(function(r) { %>
                <tr>
                  <td><%= r.amount.toFixed(2) %></td>
                  <td><%= r.method %></td>
                  <td><span class="badge <%= r.status === 'approved' ? 'badge-active' : 'badge-inactive' %>"><%= r.status %></span></td>
                  <td><%= r.requestedBy %></td>
                  <td><%= new Date(r.createdAt).toLocaleString() %></td>
                  <% if (user.role === 'superadmin' || user.role === 'subadmin') { %>
                  <td>
                    <form method="POST" action="/payment-requests/update-status/<%= r.id %>" style="display:inline">
                      <select name="status" style="padding:4px;font-size:12px;">
                        <option value="pending" <%= r.status === 'pending' ? 'selected' : '' %>>Pending</option>
                        <option value="approved" <%= r.status === 'approved' ? 'selected' : '' %>>Approved</option>
                        <option value="rejected" <%= r.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
                      </select>
                      <button type="submit" class="btn-primary" style="padding:5px 10px;font-size:12px;">Update</button>
                    </form>
                  </td>
                  <% } %>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

      </div>
    </div>
  </div>
</body>
</html>