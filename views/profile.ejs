<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Power SMS | Profile</title>
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
  <div class="layout">
    <%- include('partials/sidebar', { active: active, user: user }) %>

    <div class="main">
      <%- include('partials/topbar', { pageTitle: pageTitle, user: user }) %>

      <div class="content">

        <% if (successMsg) { %>
          <div class="page-card" style="background:#dcfce7;border-color:#86efac;color:#166534;">
            <%= successMsg %>
          </div>
        <% } %>
        <% if (errorMsg) { %>
          <div class="page-card" style="background:#fee2e2;border-color:#fca5a5;color:#991b1b;">
            <%= errorMsg %>
          </div>
        <% } %>

        <div class="page-card">
          <h3>Profile Information</h3>
          <form method="POST" action="/profile/update">
            <div class="form-row">
              <label for="name">Full Name</label>
              <input type="text" id="name" name="name" value="<%= profile.name %>" required>
            </div>
            <div class="form-row">
              <label for="username">Username</label>
              <input type="text" id="username" value="<%= profile.username %>" disabled>
            </div>
            <div class="form-row">
              <label for="email">Email</label>
              <input type="text" id="email" name="email" value="<%= profile.email %>">
            </div>
            <div class="form-row">
              <label for="country">Country</label>
              <input type="text" id="country" name="country" value="<%= profile.country %>">
            </div>
            <button type="submit" class="btn-primary">Save Changes</button>
          </form>
        </div>

        <div class="page-card">
          <h3>Change Password</h3>
          <form method="POST" action="/profile/change-password">
            <div class="form-row">
              <label for="currentPassword">Current Password</label>
              <input type="password" id="currentPassword" name="currentPassword" required>
            </div>
            <div class="form-row">
              <label for="newPassword">New Password</label>
              <input type="password" id="newPassword" name="newPassword" required minlength="6">
            </div>
            <button type="submit" class="btn-primary">Change Password</button>
          </form>
        </div>

      </div>
    </div>
  </div>
</body>
</html>